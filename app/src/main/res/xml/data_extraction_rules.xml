<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude media (photos/videos/audio) and database from cloud
             backup to preserve user privacy. Only backup app preferences. -->
        <include domain="sharedpref" path="reminera_settings.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Include everything for device-to-device migration -->
        <include domain="database" path="reminera.db"/>
        <include domain="file" path="media"/>
    </device-transfer>
</data-extraction-rules>